From 3513e6a9aeb2f09bc7fa2c0bbf82dfb392c276f3 Mon Sep 17 00:00:00 2001
From: Tobias Heider <tobias.heider@canonical.com>
Date: Fri, 21 Mar 2025 10:42:05 +0100
Subject: [PATCH 011/382] UBUNTU: SAUCE: Revert "usb: typec: ps883x: fix
 missing accessibility check"

BugLink: https://bugs.launchpad.net/bugs/2100858

This reverts commit edca39bcdaf28f5c44de6e675c6e36659abc0b7d.

The reverted commit breaks boot of the HP EliteBook G1q 14. The display goes
black and never comes back.

Signed-off-by: Tobias Heider <tobias.heider@canonical.com>
Acked-by: Juerg Haefliger <juerg.haefliger@canonical.com>
Signed-off-by: Paolo Pisati <paolo.pisati@canonical.com>
---
 drivers/usb/typec/mux/ps883x.c | 11 -----------
 1 file changed, 11 deletions(-)

diff --git a/drivers/usb/typec/mux/ps883x.c b/drivers/usb/typec/mux/ps883x.c
index 5f2879749769..563b7c623fc0 100644
--- a/drivers/usb/typec/mux/ps883x.c
+++ b/drivers/usb/typec/mux/ps883x.c
@@ -340,7 +340,6 @@ static int ps883x_retimer_probe(struct i2c_client *client)
 	struct typec_switch_desc sw_desc = { };
 	struct typec_retimer_desc rtmr_desc = { };
 	struct ps883x_retimer *retimer;
-	unsigned int val;
 	int ret;
 
 	retimer = devm_kzalloc(dev, sizeof(*retimer), GFP_KERNEL);
@@ -410,16 +409,6 @@ static int ps883x_retimer_probe(struct i2c_client *client)
 
 		/* firmware initialization delay */
 		msleep(60);
-
-		/* make sure device is accessible */
-		ret = regmap_read(retimer->regmap, REG_USB_PORT_CONN_STATUS_0,
-				  &val);
-		if (ret) {
-			dev_err(dev, "failed to read conn_status_0: %d\n", ret);
-			if (ret == -ENXIO)
-				ret = -EIO;
-			goto err_clk_disable;
-		}
 	}
 
 	sw_desc.drvdata = retimer;
-- 
2.53.0

