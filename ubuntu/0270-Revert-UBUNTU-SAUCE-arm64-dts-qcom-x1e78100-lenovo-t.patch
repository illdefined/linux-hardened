From f797df61a1b13205baf14d6cb97b3495ab523384 Mon Sep 17 00:00:00 2001
From: Tobias Heider <me@tobhe.de>
Date: Fri, 16 Jan 2026 15:01:57 +0100
Subject: [PATCH 270/382] Revert "UBUNTU: SAUCE: arm64: dts: qcom:
 x1e78100-lenovo-thinkpad-t14s: add HDMI nodes"

This reverts commit 46b886e665eb4417eec484bed3a4823d27d679bc.
---
 .../qcom/x1e78100-lenovo-thinkpad-t14s.dtsi   | 43 -------------------
 1 file changed, 43 deletions(-)

diff --git a/arch/arm64/boot/dts/qcom/x1e78100-lenovo-thinkpad-t14s.dtsi b/arch/arm64/boot/dts/qcom/x1e78100-lenovo-thinkpad-t14s.dtsi
index a7a4d04fd5a3..c665cf44415b 100644
--- a/arch/arm64/boot/dts/qcom/x1e78100-lenovo-thinkpad-t14s.dtsi
+++ b/arch/arm64/boot/dts/qcom/x1e78100-lenovo-thinkpad-t14s.dtsi
@@ -66,20 +66,6 @@ switch-lid {
 		};
 	};
 
-
-	hdmi-connector {
-		compatible = "hdmi-connector";
-		type = "a";
-		pinctrl-0 = <&hdmi_hpd_default>;
-		pinctrl-names = "default";
-
-		port {
-			hdmi_con: endpoint {
-				remote-endpoint = <&usb_1_ss2_qmpphy_out>;
-			};
-		};
-	};
-
 	pmic-glink {
 		compatible = "qcom,x1e80100-pmic-glink",
 			     "qcom,sm8550-pmic-glink",
@@ -1147,14 +1133,6 @@ &mdss_dp1_out {
 	link-frequencies = /bits/ 64 <1620000000 2700000000 5400000000 8100000000>;
 };
 
-&mdss_dp2 {
-	status = "okay";
-};
-
-&mdss_dp2_out {
-	data-lanes = <0 1 2 3>;
-};
-
 &mdss_dp3 {
 	/delete-property/ #sound-dai-cells;
 
@@ -1434,11 +1412,6 @@ &tlmm {
 	ec_int_n_default: ec-int-n-state {
 		pins = "gpio66";
 		function = "gpio";
-	};
-
-	hdmi_hpd_default: hdmi-hpd-default-state {
-		pins = "gpio126";
-		function = "usb2_dp";
 		bias-disable;
 	};
 
@@ -1696,22 +1669,6 @@ &usb_1_ss0_qmpphy_out {
 	remote-endpoint = <&retimer_ss0_ss_in>;
 };
 
-&usb_1_ss2_qmpphy {
-	vdda-phy-supply = <&vreg_l2j_1p2>;
-	vdda-pll-supply = <&vreg_l2d_0p9>;
-
-	qcom,combo-initial-mode = "dp";
-
-	/delete-property/ mode-switch;
-	/delete-property/ orientation-switch;
-
-	status = "okay";
-};
-
-&usb_1_ss2_qmpphy_out {
-	remote-endpoint = <&hdmi_con>;
-};
-
 &usb_1_ss1_hsphy {
 	vdd-supply = <&vreg_l3j_0p8>;
 	vdda12-supply = <&vreg_l2j_1p2>;
-- 
2.53.0

